{
  "name": "Python Notebook",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers"
      ],
      "settings": {
        "jupyter.defaultKernel": "python3",
        "notebook.kernelProviderAssociations": {}        
      }
    }
  },
  "postCreateCommand": "pip install jupyter ipykernel && python -m ipykernel install --user --name python3 --display-name 'Python 3'",
  "forwardPorts": []
}
