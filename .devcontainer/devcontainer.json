{
  "name": "Python Notebook",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers"
      ],
      "settings": {
        "jupyter.defaultKernel": "python3",
        "python.defaultInterpreterPath": "~/.python/current/bin/python",
        "notebook.kernelProviderAssociations": {}
              
      }
    }
  },
  "forwardPorts": []
}
